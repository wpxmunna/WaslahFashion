# Copy to .env and fill in.

# New clean-schema database for the Next.js app.
DATABASE_URL="mysql://user:password@localhost:3307/waslah_fashion"

# Legacy PHP database, read-only — used only by `npm run migrate:data`.
LEGACY_DATABASE_URL="mysql://user:password@localhost:3306/waslah_ecom"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Waslah"

# --- Branding (white-label) --------------------------------------------------
# Pick the ACTIVE brand profile by name. This one line skins the whole site
# (storefront + admin): colours, fonts and logos. Profiles are defined in
# src/lib/brand.ts — add your own there, then name it here.
NEXT_PUBLIC_BRAND_PROFILE="waslah"

# Optional per-deployment overrides that win over the active profile (handy for
# a quick tweak without editing a profile). Text colour is auto-derived for
# contrast. Supply logos with a TRANSPARENT background so they sit cleanly on
# the coloured header.
# NEXT_PUBLIC_BRAND_PRIMARY="#14423B"
# NEXT_PUBLIC_BRAND_ACCENT="#D4AF37"
# NEXT_PUBLIC_BRAND_LOGO_LOCKUP="/brand/your-logo.png"
# NEXT_PUBLIC_BRAND_LOGO_WORDMARK="/brand/your-wordmark.png"
# NEXT_PUBLIC_BRAND_LOGO_ICON="/brand/your-icon.png"
