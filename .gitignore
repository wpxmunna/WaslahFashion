# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma client is generated from schema.prisma — run `npx prisma generate`
/src/generated/

# Runtime uploads (product images, receipts, employee photos).
# Served by the /uploads/[...path] route handler, NOT from public/ (next start
# won't serve files added to public/ after boot).
/uploads/*
!/uploads/.gitkeep
/public/uploads/*
!/public/uploads/.gitkeep

# Playwright
/test-results/
/playwright-report/

# Keep the env template, which holds no secrets
!.env.example
